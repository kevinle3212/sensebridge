#!/usr/bin/env bash
#
# pre-commit — dependency-free local gate before every commit.
#
# Runs, in order: secret scan of staged changes (gitleaks + ggshield, each
# advisory if not installed), the sensitive-file check
# (tools/check-sensitive-files.mjs), the mirrored-skill drift check
# (tools/sync-skills.mjs --check), Swift lint/format (scripts/lint.sh, which
# no-ops until app/ exists), and — only when staged changes touch website/ —
# website/'s lint-staged (eslint/stylelint/prettier) and React Doctor
# (--staged --blocking warning), both scoped to the staged files only.
#
# Enabled by `git config core.hooksPath .githooks` — scripts/setup.sh does
# this. Bypass in an emergency with `git commit --no-verify` and say so in
# the PR.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if command -v gitleaks >/dev/null 2>&1; then
	gitleaks protect --staged --redact --config .gitleaks.toml
else
	echo "pre-commit: gitleaks not installed (brew install gitleaks) — skipping local secret scan; CI still scans." >&2
fi

if command -v ggshield >/dev/null 2>&1; then
	ggshield secret scan pre-commit
else
	echo "pre-commit: ggshield not installed (brew install ggshield; then ggshield auth login) — skipping GitGuardian scan; CI still scans." >&2
fi

if command -v node >/dev/null 2>&1; then
	node tools/check-sensitive-files.mjs
	node tools/sync-skills.mjs --check
else
	echo "pre-commit: node not installed — skipping sensitive-file check and mirrored-skill drift check; CI still scans." >&2
fi

./scripts/lint.sh

if git diff --cached --name-only | grep -q '^website/'; then
	if [ -d website/node_modules ]; then
		(cd website && npx lint-staged)
		(cd website && npx react-doctor --staged --blocking warning --no-telemetry)
	else
		echo "pre-commit: website/node_modules not installed (run 'npm install' in website/) — skipping website lint-staged and React Doctor; CI still lints/scans." >&2
	fi
fi
