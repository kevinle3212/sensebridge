    "Gives cautious alerts about what may be nearby. Not a safety device.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Gives cautious alerts about what may be nearby. Not a safety device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Da alertas cautelosas sobre lo que podría haber cerca. No es un dispositivo de seguridad."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đưa ra cảnh báo thận trọng về những gì có thể ở gần. Đây không phải là thiết bị an toàn."
          }
        }
      }
    },
