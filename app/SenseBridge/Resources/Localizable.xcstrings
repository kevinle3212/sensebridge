        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comienza alertas cautelosas sobre lo que podría haber cerca. Esto no es una función de seguridad."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bắt đầu cảnh báo thận trọng về những gì có thể ở gần. Đây không phải là tính năng an toàn."
          }
        }
      }
    },
    "Begins listening for recognizable sounds nearby.": {
