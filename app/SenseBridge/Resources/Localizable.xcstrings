  "strings": {
    "Announces recognized sounds nearby.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Announces recognized sounds nearby."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Anuncia los sonidos reconocidos cerca."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thông báo các âm thanh nhận dạng được ở gần."
          }
        }
      }
    },
