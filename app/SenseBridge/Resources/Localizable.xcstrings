          }
        }
      }
    },
    "Important: obstacle awareness is not a safety or mobility device. It does not replace a cane, a guide dog, or orientation-and-mobility training.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Important: obstacle awareness is not a safety or mobility device. It does not replace a cane, a guide dog, or orientation-and-mobility training."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importante: la alerta de obstáculos no es un dispositivo de seguridad ni de movilidad. No reemplaza a un bastón, un perro guía ni el entrenamiento en orientación y movilidad."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quan trọng: cảnh báo chướng ngại vật không phải là thiết bị an toàn hay hỗ trợ di chuyển. Nó không thay thế gậy dò đường, chó dẫn đường hay việc huấn luyện định hướng và di chuyển."
          }
        }
      }
    },
    "Language": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Language"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Idioma"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngôn ngữ"
          }
        }
      }
    },
    "Listens for recognizable sounds nearby and announces them.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Listens for recognizable sounds nearby and announces them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escucha sonidos reconocibles cerca y los anuncia."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lắng nghe các âm thanh có thể nhận dạng ở gần và thông báo chúng."
          }
        }
      }
    },
    "Obstacle awareness": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Obstacle awareness"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alerta de obstáculos"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cảnh báo chướng ngại vật"
          }
        }
      }
    },
    "Obstacle awareness is not a safety or mobility device. It does not replace a cane, a guide dog, or orientation-and-mobility training. It gives cautious, probabilistic alerts only.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Obstacle awareness is not a safety or mobility device. It does not replace a cane, a guide dog, or orientation-and-mobility training. It gives cautious, probabilistic alerts only."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La alerta de obstáculos no es un dispositivo de seguridad ni de movilidad. No reemplaza a un bastón, un perro guía ni el entrenamiento en orientación y movilidad. Solo da alertas cautelosas y probabilísticas."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cảnh báo chướng ngại vật không phải là thiết bị an toàn hay hỗ trợ di chuyển. Nó không thay thế gậy dò đường, chó dẫn đường hay việc huấn luyện định hướng và di chuyển. Nó chỉ đưa ra cảnh báo thận trọng, mang tính xác suất."
          }
        }
      }
    },
    "Point the camera at a scene, then capture, for a hedged description of what's there.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Point the camera at a scene, then capture, for a hedged description of what's there."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apunta la cámara a una escena y captura para obtener una descripción cautelosa de lo que hay."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hướng camera vào một khung cảnh rồi chụp để có mô tả thận trọng về những gì ở đó."
          }
        }
      }
    },
    "Point the camera at an object, then capture, to hear what it might be.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Point the camera at an object, then capture, to hear what it might be."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apunta la cámara a un objeto y captura para escuchar qué podría ser."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hướng camera vào một vật thể rồi chụp để nghe đó có thể là gì."
          }
        }
      }
    },
    "Point the camera at text, then capture, to hear it read aloud.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Point the camera at text, then capture, to hear it read aloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apunta la cámara al texto y captura para escucharlo leído en voz alta."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hướng camera vào văn bản rồi chụp để nghe đọc to."
          }
        }
      }
    },
