{
  "plugins": ["prettier-plugin-astro"],
  "printWidth": 100,
  "proseWrap": "preserve",
  "htmlWhitespaceSensitivity": "css",
  "semi": true,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf"
}
