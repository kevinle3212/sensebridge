# Only needed locally to run `npm run generate:audio` — never deployed, and
# never read by the site itself (there is no backend). See README.md's
# "Natural voice narration (ElevenLabs)" section.
#
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional overrides. Defaults are ElevenLabs' standard "Rachel" voice and
# the eleven_turbo_v2_5 model (a good latency/cost/quality balance).
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
