{
  "name": "sensebridge-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Static marketing site for SenseBridge, built with Astro (static output, zero-JS by default).",
  "license": "Apache-2.0",
  "author": "Kevin Le <https://www.linkedin.com/in/lekevin1>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinle3212/sensebridge.git",
    "directory": "website"
  },
  "homepage": "https://github.com/kevinle3212/sensebridge/tree/main/website#readme",
  "bugs": {
    "url": "https://github.com/kevinle3212/sensebridge/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint:js": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "generate:audio": "node --env-file-if-exists=.env scripts/generate-audio.js",
    "check:audio": "node scripts/generate-audio.js --check",
    "test:a11y": "pa11y-ci --config .pa11yci.json"
  },
  "dependencies": {
    "astro": "^7.1.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "astro-eslint-parser": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^3.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "lint-staged": "^17.0.8",
    "pa11y-ci": "^4.1.1",
    "prettier": "^3.4.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "lint-staged": {
    "**/*.{js,ts,astro}": "eslint --fix",
    "**/*.scss": "stylelint --fix",
    "**/*.{js,ts,scss,json,md}": "prettier --write"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.3": true
  }
}
