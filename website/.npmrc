# Fail installs if the local Node/npm version doesn't satisfy package.json's "engines" range,
# instead of just warning.
engine-strict=true

# eslint-plugin-jsx-a11y@6.10.2's peerDependencies still cap at "eslint@^9" even
# though it's a plain AST/rule-API plugin with no ESLint-10-specific breakage —
# eslint-plugin-astro's jsx-a11y-strict config (which we use) hard-requires
# eslint>=10 and pulls jsx-a11y in as its own peer, so the two plugins disagree
# on a range npm can't reconcile automatically. Relax peer resolution instead of
# waiting on jsx-a11y's peer-range bump; package.json's own version ranges are
# unaffected.
legacy-peer-deps=true
