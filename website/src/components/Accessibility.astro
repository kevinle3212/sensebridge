---
/**
 * Accessibility section: describes SenseBridge's screen-reader-first
 * approach and embeds the ReadAloud demo. Renders a Signal Spine stage
 * marker for the "spoken output" stage.
 */
import styles from "./Accessibility.module.scss";
import ReadAloud from "./ReadAloud.astro";
import SpineNode from "./SpineNode.astro";
import { useTranslations, type Locale } from "../i18n";

const t = useTranslations((Astro.currentLocale ?? "en") as Locale);
---

<section
  id="accessibility"
  class={styles.accessibility}
  aria-labelledby="accessibility-heading"
  data-stage
>
  <!-- Signal Spine's "spoken output" stage marker (DESIGN.md "Signal
       Spine"). -->
  <SpineNode top="4rem" />
  <div class="wrap">
    <h2 id="accessibility-heading">{t.accessibility.heading}</h2>
    <p class={styles.body} data-reveal-item>{t.accessibility.body}</p>
    <p class={styles["lead-in"]} data-reveal-item>{t.accessibility.leadIn}</p>
    <ReadAloud />
  </div>
</section>
