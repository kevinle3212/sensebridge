---
import styles from "./FollowProgress.module.scss";
---

<section
  id="follow-progress"
  class={styles["follow-progress"]}
  aria-labelledby="follow-progress-heading"
>
  <div class="wrap" data-reveal>
    <h2 id="follow-progress-heading">Developed in the open</h2>
    <p class={styles.body}>
      Every line of SenseBridge is public — the code, the decisions, and the distance still to go.
      Watch the repository to follow progress, read the architecture, or contribute.
    </p>
    <a class={styles.link} href="https://github.com/kevinle3212/sensebridge">
      Follow SenseBridge on GitHub
    </a>
  </div>
</section>
