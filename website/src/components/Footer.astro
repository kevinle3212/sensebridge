---
/** Renders the site footer: tagline, GitHub link, and "not yet available" notice. */
import { useTranslations, type Locale } from "../i18n";

const t = useTranslations((Astro.currentLocale ?? "en") as Locale);
---

<footer class="site-footer">
  <div class="wrap">
    <p>{t.footer.tagline}</p>
    <p>
      <a href="https://github.com/kevinle3212/sensebridge">{t.footer.githubLink}</a>
    </p>
    <p>{t.footer.notAvailable}</p>
  </div>
</footer>

<style lang="scss">
  @use "@styles/abstracts" as *;

  .site-footer {
    @include type-small;
    padding-block: space("3");
    border-top: 1px solid color("hairline");
    color: color("text-secondary");

    p + p {
      margin-top: space("1");
    }
  }
</style>
