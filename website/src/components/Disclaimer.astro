---
/** Renders the honesty-over-hype disclaimer note shown near the page footer. */
import styles from "./Disclaimer.module.scss";
import { useTranslations, type Locale } from "../i18n";

const t = useTranslations((Astro.currentLocale ?? "en") as Locale);
---

<aside class={styles.disclaimer} role="note" aria-label={t.disclaimer.ariaLabel}>
  <div class="wrap">
    <p class={styles.text}>{t.disclaimer.text}</p>
  </div>
</aside>
