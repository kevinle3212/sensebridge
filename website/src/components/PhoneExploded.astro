---
/**
 * Device section: scrollytelling exploded-phone diagram with annotation
 * blocks describing the device's sensing/haptic layers.
 */
import styles from "./PhoneExploded.module.scss";
import { useTranslations, type Locale } from "../i18n";

const t = useTranslations((Astro.currentLocale ?? "en") as Locale);

// Static fallback diagram's haptic dot grid (front face, Taptic Engine),
// coordinates only — same computed-array-in-frontmatter pattern as
// SignalBridge.astro's `joints`. Mirrors, at a smaller static count, the
// ~40-point haptic grid src/scripts/scenes/phone.ts builds in WebGL.
const hapticDotColumns = [90, 104, 118, 132];
const hapticDotRows = [195, 209, 223];
const hapticDots = hapticDotRows.flatMap((y) => hapticDotColumns.map((x) => ({ x, y })));
---

<section id="device" class={styles.device} aria-labelledby="device-title">
  <div class="wrap">
    <h2 id="device-title">{t.phone.heading}</h2>
    <p class={styles.lede} data-reveal-item>{t.phone.lede}</p>
    <p class="visually-hidden">{t.phone.diagramDescription}</p>

    <!-- Scrollytelling track: the sticky stage (a) pulls apart as the three
         real, non-hidden annotation blocks (b) scroll past — see
         src/scripts/scenes/phone.ts for the WebGL explosion this drives, and
         PhoneExploded.module.scss for the reduced-motion resting layout. -->
    <div class={styles.track} data-explode-track>
      <div class={styles.stage} data-scene="phone" aria-hidden="true">
        <!-- Static line-art exploded-phone diagram: visible by default,
             fades to 0.15 opacity once the WebGL scene mounts (same
             scene-active pattern as Hero.module.scss), and is the only thing
             shown under prefers-reduced-motion/no-JS/no-WebGL. -->
        <svg class={styles["fallback-art"]} viewBox="0 0 200 280" focusable="false">
          <rect class={styles["plate-back"]} x="20" y="15" width="110" height="200" rx="14"></rect>
          <circle class={styles.lens} cx="58" cy="52" r="9"></circle>
          <circle class={styles.lens} cx="88" cy="52" r="9"></circle>
          <circle class={styles.lidar} cx="73" cy="80" r="4"></circle>

          <line class={styles.connector} x1="75" y1="115" x2="93" y2="129"></line>
          <rect class={styles["plate-middle"]} x="38" y="29" width="110" height="200" rx="14"
          ></rect>
          <rect class={styles.chip} x="78" y="110" width="40" height="40" rx="6"></rect>
          <rect class={styles["chip-core"]} x="90" y="122" width="16" height="16"></rect>

          <line class={styles.connector} x1="93" y1="129" x2="111" y2="143"></line>
          <rect class={styles["plate-front"]} x="56" y="43" width="110" height="200" rx="14"></rect>
          <rect class={styles.speaker} x="96" y="63" width="40" height="6" rx="3"></rect>
          {
            hapticDots.map((dot) => (
              <circle class={styles["haptic-dot"]} cx={dot.x} cy={dot.y} r="2.5" />
            ))
          }
        </svg>
      </div>

      {
        t.phone.annotations.map((annotation) => (
          <div class={styles.annotation} data-reveal-block>
            <p class={styles.label}>{annotation.label}</p>
            <h3>{annotation.title}</h3>
            <p>{annotation.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
