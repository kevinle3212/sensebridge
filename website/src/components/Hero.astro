---
/**
 * Hero section: headline, lede, status line, and CTA, plus the cinematic
 * CSS/SVG hero visual. Renders the Signal Spine's "sensing" stage marker.
 */
import styles from "./Hero.module.scss";
import SpineNode from "./SpineNode.astro";
import { useTranslations, type Locale } from "../i18n";

const t = useTranslations((Astro.currentLocale ?? "en") as Locale);

// Split at build time so the visual word-by-word reveal (Phase 5) can
// stagger each word independently. The visually-hidden span below carries
// the real accessible text; the word spans live in an aria-hidden sibling,
// so VoiceOver/NVDA still read the h1 as a single plain string — never the
// duplicated/segmented markup.
const heroHeading = t.hero.heading;
const heroWords = heroHeading.split(" ");
---

<section class={styles.hero} aria-labelledby="hero-heading">
  <!-- Signal Spine's "sensing" stage marker (DESIGN.md "Signal Spine"); lit
       as part of the hero reveal timeline in src/scripts/motion.ts. -->
  <SpineNode top="6rem" />
  <div class={`wrap ${styles["hero-inner"]}`}>
    <div class={styles["hero-copy"]}>
      <h1 id="hero-heading" class={styles["hero-heading"]}>
        <span class="visually-hidden">{heroHeading}</span>
        <span aria-hidden="true">
          {
            heroWords.map((word, index) => (
              <Fragment>
                {index > 0 && " "}
                <span class={styles.word} data-hero-word>
                  {word}
                </span>
              </Fragment>
            ))
          }
        </span>
      </h1>
      <p class={styles.lede} data-hero-reveal>
        {t.hero.lede}
      </p>
      <p class={styles.status} data-hero-reveal>
        {t.hero.status}
      </p>
      <p class="visually-hidden">
        {t.hero.visuallyHiddenDescription}
      </p>
      <a
        class={styles.cta}
        data-hero-reveal
        data-magnetic
        href="https://github.com/kevinle3212/sensebridge"
      >
        {t.hero.cta}
      </a>
    </div>
    <!-- Cinematic hero visual (Phase 6): CSS/SVG only — no canvas, no
         WebGL. Three depth layers (glow / device / sensing field) tagged
         data-hero-layer for the scroll-linked parallax in src/scripts/motion.ts.
         Complete static frame under prefers-reduced-motion/no-JS: every
         layer's resting CSS state (below) is already the finished picture. -->
    <div class={styles["hero-visual"]} data-hero-visual data-scene="hero" aria-hidden="true">
      <div class={styles["visual-glow"]} data-hero-layer="glow"></div>
      <div class={styles["visual-device"]} data-hero-layer="device">
        <div class={styles["device-sweep"]}></div>
        <div class={styles["device-camera"]}></div>
      </div>
      <svg
        class={styles["device-field"]}
        data-hero-layer="field"
        viewBox="0 0 100 100"
        focusable="false"
      >
        <circle class={styles["field-ring"]} cx="50" cy="20" r="6" data-field-ring></circle>
        <circle class={styles["field-ring"]} cx="50" cy="20" r="14" data-field-ring></circle>
        <circle class={styles["field-ring"]} cx="50" cy="20" r="22" data-field-ring></circle>
      </svg>
    </div>
  </div>
</section>
