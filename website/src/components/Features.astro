---
/**
 * Features section: lists SenseBridge's core capabilities. Renders a
 * Signal Spine stage marker for the "reasoning" stage.
 */
import styles from "./Features.module.scss";
import SpineNode from "./SpineNode.astro";
import { useTranslations, type Locale } from "../i18n";

const t = useTranslations((Astro.currentLocale ?? "en") as Locale);
---

<section id="features" class={styles.features} aria-labelledby="features-heading" data-stage>
  <!-- Signal Spine's "reasoning" stage marker (DESIGN.md "Signal Spine"). -->
  <SpineNode top="4rem" />
  <div class="wrap">
    <h2 id="features-heading">{t.features.heading}</h2>
    <p class={styles.intro} data-reveal-item>{t.features.intro}</p>
    <ul class={styles.list}>
      {t.features.items.map((item) => <li data-reveal-item>{item}</li>)}
    </ul>
  </div>
</section>
