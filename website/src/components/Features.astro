---
import styles from "./Features.module.scss";
---

<section id="features" class={styles.features} aria-labelledby="features-heading">
  <div class="wrap">
    <h2 id="features-heading">What it does today</h2>
    <p class={styles.intro}>Five capabilities, all running entirely on the phone.</p>
    <ul class={styles.list}>
      <li data-reveal-item>Reads printed text and documents aloud.</li>
      <li data-reveal-item>Identifies common objects and surfaces.</li>
      <li data-reveal-item>Describes a scene in a natural sentence.</li>
      <li data-reveal-item>Gives cautious obstacle awareness using LiDAR — never navigation.</li>
      <li data-reveal-item>Announces important sound events nearby.</li>
    </ul>
  </div>
</section>
