---
import styles from "./Privacy.module.scss";
---

<section id="privacy" class={styles.privacy} aria-labelledby="privacy-heading">
  <div class="wrap" data-reveal>
    <h2 id="privacy-heading">Private by architecture, not by policy</h2>
    <p class={styles.body}>
      There is no backend, no account system, and no telemetry by default. Perception and
      reasoning run on-device; nothing about your surroundings leaves your phone without your
      explicit, revocable consent.
    </p>
    <p class={styles.supporting}>
      A privacy policy can change. An architecture with no server cannot.
    </p>
  </div>
</section>
