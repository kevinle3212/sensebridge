---
/**
 * Privacy section: explains the on-device/no-telemetry stance. Renders
 * the Signal Spine's "stays on-device" stage marker.
 */
import styles from "./Privacy.module.scss";
import SpineNode from "./SpineNode.astro";
import { useTranslations, type Locale } from "../i18n";

const t = useTranslations((Astro.currentLocale ?? "en") as Locale);
---

<section id="privacy" class={styles.privacy} aria-labelledby="privacy-heading" data-stage>
  <!-- Signal Spine's "stays on-device" stage marker (DESIGN.md "Signal
       Spine"). -->
  <SpineNode top="8rem" />
  <div class="wrap">
    <h2 id="privacy-heading">{t.privacy.heading}</h2>
    <p class={styles.body} data-reveal-item>{t.privacy.body}</p>
    <p class={styles.supporting} data-reveal-item>{t.privacy.supporting}</p>
  </div>
</section>
