---
import { getRelativeLocaleUrl } from "astro:i18n";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { translations, useTranslations, type Locale } from "../i18n";
import "../styles/global/index.scss";

interface Props {
  title?: string;
  description?: string;
}

const locale = (Astro.currentLocale ?? "en") as Locale;
const t = useTranslations(locale);
const locales = Object.keys(translations) as Locale[];

const { title = t.meta.title, description = t.meta.description } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SenseBridge" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {
      locales.map((loc) => (
        <link rel="alternate" hreflang={loc} href={getRelativeLocaleUrl(loc, "/")} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={getRelativeLocaleUrl("en", "/")} />
    <link
      rel="preload"
      href="/fonts/fraunces-variable-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/geist-variable-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script is:inline src="/theme-init.js"></script>
    {
      // react-scan (React render profiler) — gated on the frontmatter-level
      // import.meta.env.DEV check, not inside the script body: since
      // output: "static" prerenders this once at build time, the `false`
      // branch means the <script> tag itself never appears in the built
      // HTML, so zero bytes of it ship to a production visitor.
      import.meta.env.DEV && (
        <script>
          import { scan } from "react-scan";

          scan({ enabled: true });
        </script>
      )
    }
  </head>
  <body>
    <!-- "First Light" ambient 3D scene (scripts/scenes/ambient.ts): sits behind
         every page's content (see _base.scss's .ambient-scene). Decorative
         only, and only ever mounted once webglAllowed() (quality-gate.ts)
         passes — the site's complete design with this absent is the static
         CSS/SVG background it already has. -->
    <div class="ambient-scene" data-scene="ambient" aria-hidden="true"></div>
    <a class="skip-link" href="#main">{t.layout.skipLink}</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      // Motion is decoration, so its bundle (GSAP + ScrollTrigger + Lenis)
      // stays out of the critical path: load after `load`, at idle, and only
      // when the reduced-motion gate would let it run at all — a
      // reduced-motion visitor never downloads it. (If the OS preference
      // flips mid-session, from reduce to no-preference, motion stays off
      // until reload; the reverse flip is handled live by gsap.matchMedia
      // inside the module.)
      window.addEventListener(
        "load",
        () => {
          if (!window.matchMedia("(prefers-reduced-motion: no-preference)").matches) {
            return;
          }
          const idle =
            window.requestIdleCallback ??
            ((callback: IdleRequestCallback) => setTimeout(callback, 1));
          idle(() => {
            void import("../scripts/motion");
          });
        },
        { once: true },
      );
    </script>
    <script>
      // "First Light" 3D scenes (scripts/scenes/index.ts) are decoration on
      // top of decoration: same load-after-`load`, at-idle, reduced-motion
      // gate as the motion loader above, so a reduced-motion visitor never
      // even fetches this tiny entry chunk. scenes/index.ts's own
      // webglAllowed() re-checks reduced-motion (plus WebGL2/saveData/
      // deviceMemory) before it ever imports `three` itself.
      window.addEventListener(
        "load",
        () => {
          if (!window.matchMedia("(prefers-reduced-motion: no-preference)").matches) {
            return;
          }
          const idle =
            window.requestIdleCallback ??
            ((callback: IdleRequestCallback) => setTimeout(callback, 1));
          idle(() => {
            void import("../scripts/scenes/index");
          });
        },
        { once: true },
      );
    </script>
  </body>
</html>
